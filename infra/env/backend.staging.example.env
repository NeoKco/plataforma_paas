APP_NAME="Platform Backend"
APP_VERSION=0.1.0
APP_ENV=staging
DEBUG=false
PLATFORM_INSTALLED=true

CONTROL_DB_HOST=127.0.0.1
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=platform_control_staging
CONTROL_DB_USER=platform_owner
CONTROL_DB_PASSWORD=replace_me

POSTGRES_ADMIN_PASSWORD=replace_me

JWT_SECRET_KEY=replace_with_strong_staging_secret
JWT_ALGORITHM=HS256
JWT_ISSUER=platform_paas
JWT_PLATFORM_AUDIENCE=platform-api
JWT_TENANT_AUDIENCE=tenant-api
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

REDIS_URL=redis://127.0.0.1:6379/0
TENANT_PLAN_RATE_LIMITS=basic=60:20;pro=180:60;enterprise=0:0
TENANT_PLAN_ENABLED_MODULES=basic=core,users;pro=core,users,finance;pro_maintenance=core,users,maintenance;enterprise=all
TENANT_PLAN_MODULE_LIMITS=basic=finance.entries:100;pro=finance.entries:0
TENANT_BILLING_GRACE_RATE_LIMITS=20:5
TENANT_BILLING_GRACE_ENABLED_MODULES=core,users
TENANT_BILLING_GRACE_MODULE_LIMITS=finance.entries:25
BILLING_STRIPE_WEBHOOK_SECRET=replace_me
BILLING_STRIPE_WEBHOOK_TOLERANCE_SECONDS=300
BILLING_ALERT_DUPLICATE_EVENTS_THRESHOLD=10
BILLING_ALERT_IGNORED_EVENTS_THRESHOLD=5
BILLING_ALERT_PROVIDER_EVENTS_THRESHOLD=100
TENANT_API_RATE_LIMIT_BACKEND=redis
TENANT_API_RATE_LIMIT_REDIS_URL=
TENANT_API_RATE_LIMIT_KEY_PREFIX=platform_paas:tenant_rate_limit
PROVISIONING_DISPATCH_BACKEND=broker
PROVISIONING_BROKER_URL=
PROVISIONING_BROKER_KEY_PREFIX=platform_paas:provisioning_broker
PROVISIONING_BROKER_PROCESSING_LEASE_SECONDS=300
PROVISIONING_BROKER_DLQ_RETENTION_SECONDS=0
