[Unit]
Description=Platform PaaS platform_control backup
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=platform
Group=platform
EnvironmentFile=/opt/platform_paas/.env
Environment=BACKUP_DIR=/var/backups/platform_paas
Environment=DB_HOST=127.0.0.1
Environment=DB_PORT=5432
Environment=DB_NAME=platform_control
Environment=DB_USER=platform_owner
Environment=RETENTION_DAYS=7
ExecStart=/opt/platform_paas/infra/postgres/backups/backup_platform_control.sh
