[Unit]
Description=Run tenant restore drills
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=platform
Group=platform
WorkingDirectory=/opt/platform_paas/backend
EnvironmentFile=/opt/platform_paas/infra/env/restore.drill.tenants.env
ExecStart=/opt/platform_paas/platform_paas_venv/bin/python app/scripts/run_tenant_restore_drills.py --backup-dir /var/backups/platform_paas/tenants
