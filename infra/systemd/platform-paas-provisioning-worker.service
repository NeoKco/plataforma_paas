[Unit]
Description=Run provisioning worker once for pending jobs
After=postgresql.service
Wants=postgresql.service

[Service]
Type=oneshot
User=platform
Group=platform
WorkingDirectory=/opt/platform_paas/backend
EnvironmentFile=/opt/platform_paas/.env
ExecStart=/opt/platform_paas/platform_paas_venv/bin/python app/scripts/run_provisioning_worker.py --once
