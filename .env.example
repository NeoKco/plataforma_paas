APP_ENV=development
DEBUG=true

BACKEND_CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://192.168.7.42:5173

CONTROL_DB_HOST=127.0.0.1
CONTROL_DB_PORT=5432
CONTROL_DB_NAME=platform_control
CONTROL_DB_USER=platform_owner
CONTROL_DB_PASSWORD=change_me

POSTGRES_ADMIN_PASSWORD=change_me
TENANT_SECRETS_FILE=/home/felipe/platform_paas/.tenant-secrets.env
TENANT_DATA_EXPORT_ARTIFACTS_DIR=/home/felipe/platform_paas/storage/tenant_data_exports

# Solo para baseline demo/local. En produccion debes reemplazar cualquier
# password bootstrap tenant de ejemplo por secretos fuertes y unicos.
# El backend rechazara valores debiles o de demo cuando APP_ENV=production.
# TENANT_BOOTSTRAP_DB_PASSWORD_EMPRESA_BOOTSTRAP=
# TENANT_BOOTSTRAP_DB_PASSWORD_CONDOMINIO_DEMO=

JWT_SECRET_KEY=change_this_secret_in_production
JWT_ALGORITHM=HS256
JWT_ISSUER=platform_paas
JWT_PLATFORM_AUDIENCE=platform-api
JWT_TENANT_AUDIENCE=tenant-api
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_MINUTES=480

TENANT_API_RATE_LIMIT_BACKEND=memory

# Optional plan overrides. The backend already ships with a default baseline:
# mensual, trimestral, semestral, anual
# TENANT_PLAN_RATE_LIMITS=
# TENANT_PLAN_ENABLED_MODULES=
# TENANT_PLAN_MODULE_LIMITS=
# TENANT_BILLING_GRACE_RATE_LIMITS=20:5
# TENANT_BILLING_GRACE_ENABLED_MODULES=core,users
# TENANT_BILLING_GRACE_MODULE_LIMITS=finance.entries:25
